# Optional: point the app at your Cloudflare Worker proxy so end users never
# enter a Claude key. Copy this file to `.env.local` and fill in your Worker URL
# (no trailing slash), then run `npm run deploy`.
#
# Leave unset to keep the default behavior (each user enters their own key).
VITE_PROXY_URL=https://confer-proxy.YOUR-SUBDOMAIN.workers.dev
